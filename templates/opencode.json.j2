{
    "$schema": "https://opencode.ai/config.json",
    "model": "{{ ai_model }}",
    "small_model": "{{ ai_small_model }}",
    "autoupdate": "notify",
    "share": "manual",
    "provider": {{ ai_opencode_providers | to_json }},
    "disabled_providers": {{ ai_opencode_disabled_providers | to_json }},
    "permission": {
      "bash": {
        "*": "ask",
        ".specify/scripts/bash/*": "allow",
        "ansible-lint": "allow",
        "echo *": "allow",
        "find *": "allow",
        "gh issue view *": "allow",
        "gh issue list *": "allow",
        "gh pr checks *": "allow",
        "gh pr diff *": "allow",
        "gh pr view *": "allow",
        "gh repo view *": "allow",
        "gh run view *": "allow",
        "git branch*": "allow",
        "git checkout*": "allow",
        "git commit *": "ask",
        "git diff*": "allow",
        "git fetch*": "allow",
        "git log*": "allow",
        "git push *": "ask",
        "git pull*": "allow",
        "git status*": "allow",
        "go *": "allow",
        "jq *": "allow",
        "ls *": "allow",
        "make lint": "allow",
        "make test": "allow",
        "openspec *": "allow",
        "rm *": "ask",
        "test *": "allow",
        "sort *": "allow",
        "specify *": "allow",
        "wc *": "allow",
        "which *": "allow",
        "yamllint *": "allow",
      },
      "edit": "allow",
      "read": {
        "*": "allow",
        "*.env": "deny",
        "*.env.*": "deny",
        "*.key": "deny",
        "*.pem": "deny",
        "*.crt": "deny",
        "*.cer": "deny",
        "*.p12": "deny",
        "*.p8": "deny"
      }
    },
    "compaction": {
      "auto": true,
      "prune": true,
      "reserved": 10000
    },
    "instructions": {{ ai_opencode_instructions | to_json }},
    "watcher": {
      "ignore": ["node_modules/**", "dist/**", ".git/**", "vendor/**"]
    }
}
